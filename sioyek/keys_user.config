# Theme switching
# ! = white, @ = sepia, # = dark
_theme_white;reload  !
_theme_sepia;reload  @
_theme_dark;reload   #

# Toggle custom color on/off (current theme <-> normal)
toggle_custom_color  <C-r>

# Embed annotations so other readers can see highlights
embed_annotations s
external_search S

# Page navigation
next_page J
next_page <C-d>
previous_page K
previous_page <C-u>

# Yank (copy) selected text
copy y

# Close current window with q, quit all with Ctrl+W
close_window q
quit <C-w>

# File opening: o = recent, O = embedded, Ctrl+O = system
open_prev_doc o
open_document_embedded O
open_document <C-o>

# Go to top left/right of page
# goto_top_of_page;goto_right zl
# goto_top_of_page;goto_left zh

# Table of contents with T, new window with t
open_table_of_contents T
new_window t
